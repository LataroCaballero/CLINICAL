# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/clinical_db

# JWT signing secret
JWT_SECRET=your-jwt-secret-here

# AES-256-GCM encryption for WABA access tokens (32-byte hex = 64 hex chars)
ENCRYPTION_KEY=64-character-hex-string-here

# Public URL for this backend (used by WhatsApp Cloud API to fetch presupuesto PDFs)
# MUST be a publicly accessible URL in production — Meta cannot fetch localhost URLs
BACKEND_URL=https://api.yourdomain.com

# Redis for BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379

# WhatsApp / Meta HMAC webhook signature verification
META_APP_SECRET=your_meta_app_secret_from_meta_developer_dashboard
